@{
    var modalId = ViewData["DeleteModalId"]?.ToString() ?? "entityDeletePopup";
    var hiddenInputId = ViewData["DeleteHiddenInputId"]?.ToString() ?? "popupEntityId";
    var messageId = ViewData["DeleteMessageId"]?.ToString() ?? "deletePopupMessage";
    var entityLabel = ViewData["DeleteEntityLabel"]?.ToString() ?? "item";
}

<div class="modal fade admin-delete-modal" id="@modalId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered admin-delete-modal-dialog">
        <div class="modal-content modal-delete-content text-center shadow-lg">
            <div class="modal-delete-icon-box shadow-sm">
                <i class="bi bi-exclamation-triangle fs-2"></i>
            </div>

            <p class="text-dark opacity-90 px-2 small mb-4" id="@messageId">
                Are you sure you want to delete this @entityLabel? This action is permanent and cannot be undone.
            </p>

            <form method="post" asp-action="Delete">
                <input type="hidden" name="id" id="@hiddenInputId" value="" />

                <div class="d-grid gap-2 mx-auto admin-delete-actions">
                    <button type="submit" class="btn btn-confirm-delete shadow-sm">Confirm Deletion</button>
                    <button type="button" class="btn btn-cancel-delete mt-1" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        var modalEl = document.getElementById('@modalId');
        if (modalEl) {
            modalEl.addEventListener('show.bs.modal', function () {
                document.body.classList.add('admin-delete-modal-open');
            });
            modalEl.addEventListener('hidden.bs.modal', function () {
                document.body.classList.remove('admin-delete-modal-open');
            });
        }
    })();

    function openDeletePopup(entityId, entityName) {
        document.getElementById('@hiddenInputId').value = entityId;
        document.getElementById('@messageId').innerHTML =
            'Are you sure you want to delete <strong>' + entityName + '</strong>? This action is permanent and cannot be undone.';

        var deleteModal = bootstrap.Modal.getOrCreateInstance(document.getElementById('@modalId'));
        deleteModal.show();
    }
</script>
