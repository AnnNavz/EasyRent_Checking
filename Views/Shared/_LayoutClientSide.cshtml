@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EasyRent</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/client.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="client-body">
    @{
        var activeNav = ViewData["ActiveNav"]?.ToString() ?? "";
    }

    <header class="client-navbar">
        <div class="client-navbar-inner">
            <a asp-controller="Vehicles" asp-action="Homepage" class="client-brand">
                <span class="client-brand-logo">L</span>
                <span class="client-brand-name">EasyRent</span>
            </a>

            <nav class="client-nav-links d-none d-lg-flex">
                <a asp-controller="Vehicles" asp-action="Homepage" class="client-nav-link @(activeNav == "Home" ? "active" : "")">Home</a>
                <a asp-controller="Vehicles" asp-action="Browse" class="client-nav-link @(activeNav == "Vehicles" ? "active" : "")">Vehicles</a>
                <a href="#how-it-works" class="client-nav-link @(activeNav == "HowItWorks" ? "active" : "")">How It Works</a>
                <a href="#about-us" class="client-nav-link @(activeNav == "AboutUs" ? "active" : "")">About Us</a>
                <a href="#faqs" class="client-nav-link @(activeNav == "FAQs" ? "active" : "")">FAQs</a>
            </nav>

            <div class="client-nav-actions d-none d-lg-flex">
                <a asp-controller="Account" asp-action="Registration" class="client-btn-signin">Sign In</a>
            </div>

            <button class="client-nav-toggle d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#clientNavMenu" aria-controls="clientNavMenu" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div class="collapse d-lg-none" id="clientNavMenu">
            <div class="client-nav-mobile">
                <nav class="client-nav-links">
                    <a asp-controller="Vehicles" asp-action="Homepage" class="client-nav-link @(activeNav == "Home" ? "active" : "")">Home</a>
                    <a asp-controller="Vehicles" asp-action="Browse" class="client-nav-link @(activeNav == "Vehicles" ? "active" : "")">Vehicles</a>
                    <a href="#how-it-works" class="client-nav-link @(activeNav == "HowItWorks" ? "active" : "")">How It Works</a>
                    <a href="#about-us" class="client-nav-link @(activeNav == "AboutUs" ? "active" : "")">About Us</a>
                    <a href="#faqs" class="client-nav-link @(activeNav == "FAQs" ? "active" : "")">FAQs</a>
                </nav>
                <a asp-controller="Account" asp-action="Registration" class="client-btn-signin">Sign In</a>
            </div>
        </div>
    </header>

    <main class="client-main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
