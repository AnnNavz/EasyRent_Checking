@model IEnumerable<EasyRent_Checking.Models.Vehicle>

@{
    Layout = "~/Views/Shared/_LayoutClientSide.cshtml";
    ViewData["Title"] = "Vehicles";
    ViewData["SectionTitle"] = "Vehicles";
    ViewData["ActivePage"] = "Vehicles";
}

<div class="client-page-header">
    <h1>Browse Vehicles</h1>
    <p>Explore our available fleet and find the right vehicle for your rental needs.</p>
</div>

@if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="blueprint-vehicle-card">
                    <div class="blueprint-image-bounding-box">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="/images/@item.ImagePath" class="blueprint-img-tag" alt="@item.Model" />
                        }
                        else
                        {
                            <svg viewBox="0 0 100 100" preserveAspectRatio="none" style="width: 100%; height: 100%; stroke: #222; stroke-width: 0.8; opacity: 0.85;">
                                <line x1="0" y1="0" x2="100" y2="100" />
                                <line x1="100" y1="0" x2="0" y2="100" />
                            </svg>
                        }
                        <div class="blueprint-status-pill">@item.Status</div>
                    </div>

                    <div class="card-meta-details-box">
                        <div class="meta-primary-row">
                            <h2 class="vehicle-model-header">@item.Model</h2>
                            <div class="d-flex align-items-center">
                                <span class="color-dot-indicator"></span>
                                <span class="color-text-lbl">@item.Color</span>
                            </div>
                        </div>
                        <div class="vehicle-make-sub">@item.Brand</div>
                    </div>

                    <div>
                        <a asp-action="Details" asp-route-id="@item.VehicleId" class="blueprint-btn-action">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="client-empty-state">
        <i class="bi bi-car-front d-block"></i>
        <p class="mb-0 fw-semibold">No vehicles are available right now.</p>
        <p class="small text-muted mt-1">Please check back later for new listings.</p>
    </div>
}
