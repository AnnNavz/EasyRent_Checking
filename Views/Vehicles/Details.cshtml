@model EasyRent_Checking.Models.Vehicle

@{
    Layout = "_LayoutAdminDashboard";
    ViewData["Title"] = "View Details";
    ViewData["ActivePage"] = "Vehicles";

    string registrationFrom = Model?.RegistrationDate.ToString("MMMM dd, yyyy") ?? "—";
    string registrationTo = Model?.RegistrationExpiry.ToString("MMMM dd, yyyy") ?? "—";
    string detailsReturnUrl = Url.Action("Details", new { id = Model?.VehicleId }) ?? "";
}

<div class="container-fluid px-4 py-3">

    <div class="details-page-header">
        <div class="d-flex align-items-center gap-4 flex-grow-1">
            <div class="vehicle-details-image">
                @if (!string.IsNullOrEmpty(Model?.ImagePath))
                {
                    <img src="~/images/@Model.ImagePath" alt="@Model.Model" />
                }
                else
                {
                    <div class="license-preview-placeholder"></div>
                }
            </div>
            <div>
                <h1 class="vehicle-details-model mb-1">@Model?.Model</h1>
                <p class="vehicle-details-brand mb-0">@Model?.Brand</p>
            </div>
        </div>
        <div class="details-page-actions">
            <a asp-action="Index" class="btn btn-page-back">Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.VehicleId" asp-route-returnUrl="@detailsReturnUrl" class="btn btn-page-primary">Edit Vehicle Information</a>
        </div>
    </div>

    <ul class="nav nav-tabs vehicle-details-tabs mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" type="button" role="tab" aria-selected="true">Information</button>
        </li>
    </ul>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="vehicle-info-card shadow-sm">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-car-front fs-5 text-secondary"></i>
                    <h6 class="fw-bold mb-0 text-dark">Vehicle Details</h6>
                </div>
                <hr class="wizard-section-divider" />
                <div class="vehicle-info-row">
                    <span class="vehicle-info-label">Color</span>
                    <span class="vehicle-info-value">@Model?.Color</span>
                </div>
                <div class="vehicle-info-row">
                    <span class="vehicle-info-label">Type</span>
                    <span class="vehicle-info-value">@Model?.Type</span>
                </div>
                <div class="vehicle-info-row">
                    <span class="vehicle-info-label">Plate Number</span>
                    <span class="vehicle-info-value font-monospace text-uppercase">@Model?.PlateNumber</span>
                </div>
                <div class="vehicle-info-row">
                    <span class="vehicle-info-label">Status</span>
                    <span class="vehicle-info-value">@Model?.Status</span>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="vehicle-info-card shadow-sm">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-card-text fs-5 text-secondary"></i>
                    <h6 class="fw-bold mb-0 text-dark">Vehicle Registration Details</h6>
                </div>
                <hr class="wizard-section-divider" />
                <div class="vehicle-info-row">
                    <span class="vehicle-info-label">Valid from</span>
                    <span class="vehicle-info-value">@registrationFrom</span>
                </div>
                <div class="vehicle-info-row">
                    <span class="vehicle-info-label">Valid to</span>
                    <span class="vehicle-info-value">@registrationTo</span>
                </div>
            </div>
        </div>
    </div>
</div>
