@model IEnumerable<EasyRent_Checking.Models.Vehicle>

@{
    // Inherit the administrative design system architecture
    Layout = "_LayoutAdminDashboard";
    ViewData["Title"] = "Vehicle Management";
    ViewData["ActivePage"] = "Vehicles";

    string currentSortName = ViewData["CurrentSort"]?.ToString() == "Model" ? "Model" :
                             ViewData["CurrentSort"]?.ToString() == "Brand" ? "Brand" :
                             ViewData["CurrentSort"]?.ToString() == "PlateNumber" ? "Plate Number" : "Sorting by";

    string currentFilterName = ViewData["CurrentFilter"]?.ToString() == "Active" ? "Active" :
                               ViewData["CurrentFilter"]?.ToString() == "Maintenance" ? "Maintenance" : "Filters";

    string indexReturnUrl = Url.Action("Index", new
    {
        searchString = ViewData["CurrentSearch"],
        sortBy = ViewData["CurrentSort"],
        currentFilter = ViewData["CurrentFilter"],
        page = ViewData["PageIndex"]
    }) ?? "";
}

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="metric-card p-4 d-flex justify-content-between align-items-center">
            <div>
                <span class="metric-label">Active Vehicles</span>
                <div class="metric-value">@(ViewData["ActiveVehiclesCount"] ?? "0")</div>
            </div>
            <div class="metric-icon-box" aria-hidden="true"></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="metric-card p-4 d-flex justify-content-between align-items-center">
            <div>
                <span class="metric-label">Total Vehicles</span>
                <div class="metric-value">@(ViewData["TotalVehiclesCount"] ?? "0")</div>
            </div>
            <div class="metric-icon-box" aria-hidden="true"></div>
        </div>
    </div>
</div>

<form asp-action="Index" method="get" class="w-100">
    <input type="hidden" name="sortBy" value="@ViewData["CurrentSort"]" />
    <input type="hidden" name="currentFilter" value="@ViewData["CurrentFilter"]" />

    <div class="card index-toolbar-card mb-4">
        <div class="card-body p-3 d-flex flex-wrap align-items-center justify-content-between gap-3">

            <div class="d-flex align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle border px-3 fw-semibold text-secondary btn-filter text-capitalize" type="button" data-bs-toggle="dropdown">
                        @currentSortName
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?sortBy=Model&searchString=@ViewData["CurrentSearch"]&currentFilter=@ViewData["CurrentFilter"]">Model</a></li>
                        <li><a class="dropdown-item" href="?sortBy=Brand&searchString=@ViewData["CurrentSearch"]&currentFilter=@ViewData["CurrentFilter"]">Brand</a></li>
                        <li><a class="dropdown-item" href="?sortBy=PlateNumber&searchString=@ViewData["CurrentSearch"]&currentFilter=@ViewData["CurrentFilter"]">Plate Number</a></li>
                        <li><hr class="dropdown-menu-divider"></li>
                        <li><a class="dropdown-item text-muted small" href="?sortBy=&searchString=@ViewData["CurrentSearch"]&currentFilter=@ViewData["CurrentFilter"]">Clear Sorting</a></li>
                    </ul>
                </div>
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle border px-3 fw-semibold text-secondary btn-filter text-capitalize" type="button" data-bs-toggle="dropdown">
                        @currentFilterName
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?currentFilter=Active&searchString=@ViewData["CurrentSearch"]&sortBy=@ViewData["CurrentSort"]">Active Only</a></li>
                        <li><a class="dropdown-item" href="?currentFilter=Maintenance&searchString=@ViewData["CurrentSearch"]&sortBy=@ViewData["CurrentSort"]">Maintenance Only</a></li>
                        <li><hr class="dropdown-menu-divider"></li>
                        <li><a class="dropdown-item text-muted small" href="?currentFilter=&searchString=@ViewData["CurrentSearch"]&sortBy=@ViewData["CurrentSort"]">Clear Filters</a></li>
                    </ul>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3 flex-grow-1 flex-sm-grow-0">
                <div class="position-relative flex-grow-1">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control ps-5 pe-4 rounded-3 border bg-light text-secondary search-bar-input" placeholder="Search vehicle entries..." />
                    @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
                    {
                        <a href="?searchString=&sortBy=@ViewData["CurrentSort"]&currentFilter=@ViewData["CurrentFilter"]" class="position-absolute top-50 end-0 translate-middle-y me-3 text-secondary text-decoration-none small">✕</a>
                    }
                </div>

                <a asp-action="Create" class="btn btn-dark d-flex align-items-center gap-2 px-3 py-2 fw-bold text-nowrap rounded-3 shadow-sm btn-add-driver">
                    <i class="bi bi-plus-lg"></i> Add Vehicle
                </a>
            </div>
        </div>
    </div>
</form>

<div class="index-table-panel mb-4">
    <div class="table-responsive">
        <table class="table admin-table mb-0 align-middle">
            <thead>
                <tr>
                    <th>Model</th>
                    <th>Plate Number</th>
                    <th>Brand</th>
                    <th>Color</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Registration Date</th>
                    <th>Registration Expiry</th>
                    <th class="text-center" style="width: 60px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.Model)</td>
                            <td class="text-uppercase font-monospace text-secondary fw-semibold">@Html.DisplayFor(modelItem => item.PlateNumber)</td>
                            <td>@Html.DisplayFor(modelItem => item.Brand)</td>
                            <td>@Html.DisplayFor(modelItem => item.Color)</td>
                            <td>@Html.DisplayFor(modelItem => item.Type)</td>
                            <td>
                                @{
                                    string statusString = item.Status.ToString() ?? "";
                                }

                                @if (statusString.Equals("Available", StringComparison.OrdinalIgnoreCase) || statusString.Equals("Active", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-2 px-2.5 py-1.5 fw-bold">@statusString</span>
                                }
                                else if (statusString.Equals("InMaintenance", StringComparison.OrdinalIgnoreCase) || statusString.Equals("Maintenance", StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning rounded-2 px-2.5 py-1.5 fw-bold">@statusString</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-2 px-2.5 py-1.5 fw-bold">@statusString</span>
                                }
                            </td>
                            <td>@item.RegistrationDate.ToString("MM-dd-yyyy")</td>
                            <td>@item.RegistrationExpiry.ToString("MM-dd-yyyy")</td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-link text-dark p-0 border-0 line-height-1" type="button" data-bs-toggle="dropdown" data-bs-popper-config='{"strategy":"fixed","placement":"bottom-end"}' data-bs-boundary="viewport">
                                        <i class="bi bi-three-dots fs-5"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.VehicleId" asp-route-returnUrl="@indexReturnUrl"><i class="bi bi-pencil me-2"></i> Edit</a></li>
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.VehicleId"><i class="bi bi-info-circle me-2"></i> Details</a></li>
                                        <li><hr class="dropdown-menu-divider"></li>
                                        <li>
                                            <button type="button" class="dropdown-item text-danger" onclick="openDeletePopup('@item.VehicleId', '@item.Model')">
                                                <i class="bi bi-trash me-2"></i> Delete
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-5 text-muted fw-medium">
                            <i class="bi bi-car-front fs-2 d-block mb-2 text-secondary opacity-50"></i>
                            No matching vehicles located in fleet indexes.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <partial name="_AdminPagination" />
</div>

@{
    ViewData["DeleteModalId"] = "vehicleDeletePopup";
    ViewData["DeleteHiddenInputId"] = "popupVehicleId";
    ViewData["DeleteMessageId"] = "deletePopupMessage";
    ViewData["DeleteEntityLabel"] = "vehicle";
}
<partial name="_DeleteConfirmModal" />