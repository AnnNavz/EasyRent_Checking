@model IEnumerable<EasyRent_Checking.Models.Vehicle>

@{
    // Inherit the administrative design system architecture
    Layout = "_LayoutAdminDashboard";
    ViewData["Title"] = "Vehicle Management";
    ViewData["ActivePage"] = "Vehicles";
}

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="metric-card shadow-sm p-4 d-flex justify-content-between align-items-center bg-white rounded-4">
            <div>
                <span class="text-muted small fw-bold">Active Vehicles</span>
                <h2 class="fw-bold mt-1 mb-0 text-dark">NaN</h2>
            </div>
            <div class="metric-icon-box">
                <i class="bi bi-car-front fs-3 text-secondary"></i>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="metric-card shadow-sm p-4 d-flex justify-content-between align-items-center bg-white rounded-4">
            <div>
                <span class="text-muted small fw-bold">Total Vehicles</span>
                <h2 class="fw-bold mt-1 mb-0 text-dark">NaN</h2>
            </div>
            <div class="metric-icon-box">
                <i class="bi bi-truck fs-3 text-secondary"></i>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 bg-white rounded-4 shadow-sm mb-4">
    <div class="card-body p-3 d-flex flex-wrap align-items-center justify-content-between gap-3">

        <div class="d-flex align-items-center gap-2">
            <div class="dropdown">
                <button class="btn btn-light dropdown-toggle border px-3 fw-semibold text-secondary btn-filter" type="button" data-bs-toggle="dropdown">
                    Sorting by
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Model</a></li>
                    <li><a class="dropdown-item" href="#">Brand</a></li>
                </ul>
            </div>
            <div class="dropdown">
                <button class="btn btn-light dropdown-toggle border px-3 fw-semibold text-secondary btn-filter" type="button" data-bs-toggle="dropdown">
                    Filters
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#">Active</a></li>
                    <li><a class="dropdown-item" href="#">Maintenance</a></li>
                </ul>
            </div>
        </div>

        <div class="d-flex align-items-center gap-3 flex-grow-1 flex-sm-grow-0">
            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                <input type="text" class="form-control ps-5 pe-4 rounded-3 border bg-light text-secondary search-bar-input" placeholder="Search" />
                <i class="bi bi-mic position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
            </div>

            <a asp-action="Create" class="btn btn-dark d-flex align-items-center gap-2 px-3 py-2 fw-bold text-nowrap rounded-3 shadow-sm btn-add-driver">
                <i class="bi bi-plus-lg"></i> Add Vehicle
            </a>
        </div>
    </div>
</div>

<div class="admin-table-card shadow-sm border-0 mb-4">
    <div class="table-responsive">
        <table class="table admin-table mb-0 align-middle">
            <thead>
                <tr>
                    <th>Vehicle Model</th>
                    <th>Plate Number</th>
                    <th>Brand</th>
                    <th>Color</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th class="text-center" style="width: 60px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.Model)</td>
                            <td class="text-uppercase font-monospace text-secondary fw-semibold">@Html.DisplayFor(modelItem => item.PlateNumber)</td>
                            <td>@Html.DisplayFor(modelItem => item.Brand)</td>
                            <td>@Html.DisplayFor(modelItem => item.Color)</td>
                            <td>@Html.DisplayFor(modelItem => item.Type)</td>
                            <td>
                                @if (item.Status.ToString().ToLower() == "active")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-2 px-2.5 py-1.5 fw-bold">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-2 px-2.5 py-1.5 fw-bold">@item.Status</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-link text-dark p-0 border-0 line-height-1" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots fs-5"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.VehicleId"><i class="bi bi-pencil me-2"></i> Edit</a></li>
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.VehicleId"><i class="bi bi-info-circle me-2"></i> Details</a></li>
                                        <li><hr class="dropdown-menu-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.VehicleId"><i class="bi bi-trash me-2"></i> Delete</a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td class="fw-bold text-dark">Civic</td>
                        <td class="text-uppercase font-monospace text-secondary fw-semibold">GAC 4821</td>
                        <td>Toyota</td>
                        <td>White</td>
                        <td>SUV</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success rounded-2 px-2 py-1 fw-bold">Active</span></td>
                        <td class="text-center">
                            <button class="btn btn-link text-dark p-0 border-0" type="button">
                                <i class="bi bi-three-dots fs-5"></i>
                            </button>
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold text-dark">Odyssey</td>
                        <td class="text-uppercase font-monospace text-secondary fw-semibold">GAC 4821</td>
                        <td>Toyota</td>
                        <td>White</td>
                        <td>SUV</td>
                        <td><span class="badge bg-success bg-opacity-10 text-success rounded-2 px-2 py-1 fw-bold">Active</span></td>
                        <td class="text-center">
                            <button class="btn btn-link text-dark p-0 border-0" type="button">
                                <i class="bi bi-three-dots fs-5"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex align-items-center justify-content-between px-2 text-secondary fw-semibold mb-5 pagination-wrapper">
    <div class="small">1-10 of 97</div>
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-link text-decoration-none text-secondary p-0 border-0"><i class="bi bi-chevron-left"></i></button>
        <span class="small text-dark">1/10</span>
        <button class="btn btn-link text-decoration-none text-secondary p-0 border-0"><i class="bi bi-chevron-right"></i></button>
    </div>
</div>